# ===================================
# CONFIGURACIÓN DE ENTORNO - FASE CERO
# ===================================

# Base de Datos (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Seguridad - Criptografía AES-256-GCM
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=tu_clave_secreta_de_32_bytes_en_hexadecimal

# Servidor
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info

# Vapi (voz)
# VAPI_AUTH_TOKEN: Dashboard Vapi → Account → Webhook Secret
VAPI_AUTH_TOKEN=tu_token_vapi
WEBHOOK_SECRET=tu_webhook_secret

# WhatsApp (Meta Cloud API)
# WHATSAPP_VERIFY_TOKEN: token libre que defines tú, lo pones igual en Meta Dashboard
# WHATSAPP_PHONE_NUMBER_ID: Meta Dashboard → WhatsApp → API Setup → Phone Number ID
WHATSAPP_VERIFY_TOKEN=un_token_secreto_cualquiera
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id

# Inteligencia Artificial (Anthropic)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Timers Anti-Arrepentimiento
ABANDONMENT_TIMER_VOICE=45000
ABANDONMENT_TIMER_CHAT=300000
