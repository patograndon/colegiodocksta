# ===================================
# CONFIGURACIÓN DE ENTORNO - FASE CERO
# ===================================

# Base de Datos (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Seguridad - Criptografía AES-256-GCM
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=tu_clave_secreta_de_32_bytes_en_hexadecimal

# Servidor
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info

# Vapi & Webhooks
VAPI_AUTH_TOKEN=tu_token_vapi
WEBHOOK_SECRET=tu_webhook_secret

# Timers Anti-Arrepentimiento
ABANDONMENT_TIMER_VOICE=45000
ABANDONMENT_TIMER_CHAT=300000
